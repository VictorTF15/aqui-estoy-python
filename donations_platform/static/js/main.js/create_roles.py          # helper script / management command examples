from django.core.management.base import BaseCommand
from rbac.models import Role, Permission

class Command(BaseCommand):
    help = 'Create default roles and permissions'

    def handle(self, *args, **kwargs):
        # Create roles
        admin_role, created = Role.objects.get_or_create(name='Admin')
        donor_role, created = Role.objects.get_or_create(name='Donor')
        beneficiary_role, created = Role.objects.get_or_create(name='Beneficiary')

        # Create permissions
        view_donations_permission, created = Permission.objects.get_or_create(name='Can view donations')
        create_donations_permission, created = Permission.objects.get_or_create(name='Can create donations')
        manage_users_permission, created = Permission.objects.get_or_create(name='Can manage users')

        # Assign permissions to roles
        admin_role.permissions.add(view_donations_permission, create_donations_permission, manage_users_permission)
        donor_role.permissions.add(create_donations_permission)
        beneficiary_role.permissions.add(view_donations_permission)

        self.stdout.write(self.style.SUCCESS('Successfully created roles and permissions'))